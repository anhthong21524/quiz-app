# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# MongoDB (optional — falls back to in-memory repository if not set)
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=quiz-app

# JWT — use a long random string for production
JWT_SECRET=change-this-to-a-long-random-secret

# Admin credentials (optional — defaults shown below)
AUTH_ADMIN_EMAIL=admin@quiz.app
AUTH_ADMIN_PASSWORD=admin1234

# Google OAuth — create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Authorized redirect URI registered in Google Console (must include /api prefix)
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
